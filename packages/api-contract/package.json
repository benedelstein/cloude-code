    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:",
    "ai": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "catalog:",
