{
  "name": "@repo/vm-agent",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/vm-agent.bundle.js",
  "scripts": {
    "dev": "bun run src/index-ndjson.ts",
    "test": "vitest run --passWithNoTests",
    "build": "bun build src/index-ndjson.ts --outfile=dist/vm-agent.bundle.js --target=bun --minify && bun build src/index-webhook.ts --outfile=dist/vm-agent-webhook.bundle.js --target=bun --minify",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:live:agent": "bun run src/test-agent-aisdk.ts",
    "test:live:webhook": "bun run src/test-webhook-runner.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@repo/shared": "workspace:*",
    "ai": "catalog:",
    "ai-sdk-provider-claude-code": "^3.3.3",
    "ai-sdk-provider-codex-cli": "github:benedelstein/ai-sdk-provider-codex-cli"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "@types/bun": "^1.2.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
