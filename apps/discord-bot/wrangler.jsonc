{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloude-code-discord-bot",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "API_BASE_URL": "https://api.cloudecode.dev",
    "DISCORD_PUBLIC_KEY": "78c3ce662077661882ba7b530d5fc3bfddb9dbe032e25638469fb87b45cec7a0"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    }
  }
  // Secrets (set via wrangler secret put):
  // - INTEGRATION_SESSION_REQUEST_TOKEN
}
