# Shared secret sent as the Bearer token on POST /integrations/session-requests.
# Must match INTEGRATION_SESSION_REQUEST_TOKEN on services/api-server.
INTEGRATION_SESSION_REQUEST_TOKEN=

# Cloude API base URL. In dev this overrides the production value in
# wrangler.jsonc; point it at your local api-server.
API_BASE_URL=http://localhost:8787

# Only needed by `pnpm register-command` (not by the Worker itself).
# DISCORD_PUBLIC_KEY for the Worker is a public var in wrangler.jsonc.
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
# Omit to register the slash command globally instead of per-guild.
DISCORD_GUILD_ID=
