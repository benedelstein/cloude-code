ENVIRONMENT=development
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SPRITES_API_KEY=

# github local app
GITHUB_APP_ID=2992869
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=cloude-code-local
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=Iv23liUfelBsFgmuvuRy
GITHUB_APP_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=

# Worker URL — must be reachable from Sprites VMs.
# In dev, set this to your cloudflared tunnel URL (see docs/webhook-tunnel.md).
# This overrides the production value in wrangler.jsonc.
WORKER_URL=https://your-tunnel-subdomain.yourdomain.com

WEBSOCKET_TOKEN_SIGNING_KEY=
LOG_LEVEL=debug

# Canonical prod web origin. Used as the default redirect target on the
# /auth/github call when no origin is provided, and exempted from the
# preview-origin allowlist.
WEB_ORIGIN=http://localhost:3000

# Regex matching Vercel preview origins permitted to receive the OAuth bounce
# redirect. Must pin the project name AND the team slug as literals so other
# teams cannot produce a matching URL.
PREVIEW_ORIGIN_ALLOWLIST_REGEX=^https://cloude-code-[a-z0-9][a-z0-9-]*-benedelsteins-projects\.vercel\.app$

VOICE_TOKEN_SIGNING_KEY=

# Shared secret for POST /integrations/session-requests. Use the same value on
# every trusted integration client (e.g. apps/discord-bot).
INTEGRATION_SESSION_REQUEST_TOKEN=
