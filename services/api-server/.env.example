ENVIRONMENT=development
LOG_LEVEL=debug

# Fallback Claude API key used when user has no Claude OAuth token
ANTHROPIC_API_KEY=

# fly.io Sprites API (VM host)
SPRITES_API_KEY=
SPRITES_API_URL=https://api.sprites.dev

# GitHub App — install at https://github.com/apps/<your-app>
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# base64-encoded 32-byte AES-GCM key for per-user provider credentials
TOKEN_ENCRYPTION_KEY=
# base64-encoded HMAC key used to sign short-lived websocket auth tokens
WEBSOCKET_TOKEN_SIGNING_KEY=

# Worker URL — must be reachable from Sprites VMs.
# In dev, set this to your cloudflared tunnel URL (see docs/webhook-tunnel.md).
# This overrides the production value in wrangler.jsonc.
WORKER_URL=https://your-tunnel-subdomain.yourdomain.com