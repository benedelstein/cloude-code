{
  "name": "@repo/api-server",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler",
    "db:migrate": "wrangler d1 migrations apply cloude-code-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cloude-code-db --remote",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:live:sprite": "tsx scripts/test-sprite.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@fly/sprites": "^0.0.1",
    "@repo/shared": "workspace:*",
    "@repo/vm-agent": "workspace:*",
    "agents": "catalog:",
    "ai": "catalog:",
    "@hono/zod-openapi": "catalog:",
    "hono": "^4.6.0",
    "octokit": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "@cloudflare/workers-types": "^4.20260129.0",
    "@octokit/webhooks": "13.9.1",
    "dotenv": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "^4.60.0",
    "vitest": "catalog:"
  }
}
