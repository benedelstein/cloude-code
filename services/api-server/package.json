{
  "name": "@repo/api-server",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "lint": "eslint src/ tests/ scripts/ && pnpm lint:module-boundaries",
    "lint:module-boundaries": "node --import tsx scripts/check-module-boundaries.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler",
    "db:migrate": "wrangler d1 migrations apply cloude-code-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cloude-code-db --remote",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:live:sprite": "tsx scripts/test-sprite.ts",
    "test:live:claude-oauth-control-plane-proxy": "tsx scripts/test-claude-oauth-control-plane-proxy.ts",
    "test:live:codex-oauth-control-plane-proxy": "tsx scripts/test-codex-oauth-control-plane-proxy.ts",
    "test:fcm": "tsx scripts/test-fcm.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@fly/sprites": "^0.0.1",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "catalog:",
    "@repo/api-contract": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/vm-agent": "workspace:*",
    "agents": "catalog:",
    "ai": "catalog:",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "octokit": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260421.1",
    "@octokit/webhooks": "13.9.1",
    "@vitest/coverage-v8": "catalog:",
    "dotenv": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.84.1"
  }
}
