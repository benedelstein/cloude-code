{
  "name": "@repo/api-server",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler",
    "test-sprite": "tsx scripts/test-sprite.ts",
    "db:migrate": "wrangler d1 migrations apply cloude-code-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cloude-code-db --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@fly/sprites": "^0.0.1",
    "@repo/shared": "workspace:*",
    "@repo/vm-agent": "workspace:*",
    "agents": "catalog:",
    "ai": "catalog:",
    "hono": "^4.6.0",
    "octokit": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260129.0",
    "@octokit/webhooks": "13.9.1",
    "dotenv": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "^4.60.0"
  }
}
