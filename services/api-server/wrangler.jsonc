{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloude-code-api",
  "account_id": "fc436be76ce4378e78419c5f0c62e345",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.bundle.js"],
      "fallthrough": false
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "SPRITES_API_URL": "https://api.sprites.dev",
    "WORKER_URL": "https://cloude-code-api.bedelstein12.workers.dev",
    "GITHUB_APP_SLUG": "cloude-code",
    "GITHUB_APP_ID": "2799576",
    "ALLOWED_GITHUB_LOGINS": "benedelstein,evancarter,sidkasbekar,sidgilly,161siegels",
    "GITHUB_APP_CLIENT_ID": "Iv23lirr1sj5RthzlsAs",
    "LOG_LEVEL": "info",
  },
  "dev": {
    "port": 8787
  },
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION_AGENT",
        "class_name": "SessionAgentDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionAgentDO"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cloude-code-db",
      "database_id": "83f9e684-6771-446f-bff6-7e2eb4e6d5e3"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS_BUCKET",
      "bucket_name": "cloude-code-attachments"
    }
  ],
  "custom_domains": [
    {
      "pattern": "api.cloudecode.dev"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
  // Secrets (set via wrangler secret put):
  // - ANTHROPIC_API_KEY
  // - SPRITES_API_KEY
  // - GITHUB_APP_ID
  // - GITHUB_APP_PRIVATE_KEY
  // - GITHUB_WEBHOOK_SECRET
  // - GITHUB_APP_CLIENT_ID
  // - GITHUB_APP_CLIENT_SECRET
  // - TOKEN_ENCRYPTION_KEY
  // - WEBSOCKET_TOKEN_SIGNING_KEY
}
