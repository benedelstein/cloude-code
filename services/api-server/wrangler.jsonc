{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloude-code-api",
  "account_id": "fc436be76ce4378e78419c5f0c62e345",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.bundle.js"],
      "fallthrough": false
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "SPRITES_API_URL": "https://api.sprites.dev",
    "WORKER_URL": "https://api.mymachines.dev",
    "GITHUB_APP_SLUG": "my-machines-integration",
    "GITHUB_APP_ID": "2799576",
    "GITHUB_APP_CLIENT_ID": "Iv23lirr1sj5RthzlsAs",
    "LOG_LEVEL": "info",
    "WEB_ORIGIN": "https://www.mymachines.dev",
    "PREVIEW_ORIGIN_ALLOWLIST_REGEX": "^https://my-machines-[a-z0-9][a-z0-9-]*-benedelsteins-projects\\.vercel\\.app$",
  },
  "dev": {
    "port": 8787
  },
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION_AGENT",
        "class_name": "SessionAgentDO"
      },
      {
        "name": "USER_SESSIONS",
        "class_name": "UserSessionsDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionAgentDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["UserSessionsDO"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cloude-code-db",
      "database_id": "83f9e684-6771-446f-bff6-7e2eb4e6d5e3"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS_BUCKET",
      "bucket_name": "cloude-code-attachments"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "TURN_NOTIFICATION_QUEUE",
        "queue": "turn-notifications"
      }
    ],
    "consumers": [
      {
        "queue": "turn-notifications",
        "max_batch_size": 10,
        "max_batch_timeout": 1,
        "max_retries": 3,
        "dead_letter_queue": "turn-notifications-dlq"
      }
    ]
  },
  "routes": [
    {
      "pattern": "api.mymachines.dev",
      "custom_domain": true
    },
    // Existing iOS releases still use this hostname.
    {
      "pattern": "api.cloudecode.dev",
      "custom_domain": true
    }
  ],
  "limits": {
    "cpu_ms": 30000,
    "subrequests": 10000
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    }
  }
  // Secrets (set via wrangler secret put):
  // - ANTHROPIC_API_KEY
  // - OPENAI_API_KEY
  // - SPRITES_API_KEY
  // - GITHUB_APP_ID
  // - GITHUB_APP_PRIVATE_KEY
  // - GITHUB_WEBHOOK_SECRET
  // - GITHUB_APP_CLIENT_ID
  // - GITHUB_APP_CLIENT_SECRET
  // - TOKEN_ENCRYPTION_KEY
  // - NATIVE_ACCESS_TOKEN_SIGNING_KEY
  // - WEBSOCKET_TOKEN_SIGNING_KEY
  // - VOICE_TOKEN_SIGNING_KEY
  // - FIREBASE_SERVICE_ACCOUNT_JSON_BASE64
  // - INTEGRATION_SESSION_REQUEST_TOKEN
}
