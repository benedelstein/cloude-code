{
  "name": "cloude-code",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "turbo run dev --filter=@repo/api-server",
    "dev:web": "turbo run dev --filter=@repo/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "run:ci": "pnpm lint && pnpm typecheck && pnpm test",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:live:session": "npx tsx scripts/test-session.ts",
    "test:live:create-session": "npx tsx scripts/test-create-session.ts",
    "dev:local": "turbo run dev --parallel --ui=tui --filter=@repo/web --filter=@repo/api-server --filter=@repo/scripts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "ws": "^8.20.0"
  }
}
