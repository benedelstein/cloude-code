{
  "name": "cloude-code",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present run build",
    "dev": "corepack pnpm -r --parallel --if-present run dev",
    "dev:api": "corepack pnpm --filter @repo/api-server run dev",
    "dev:web": "corepack pnpm --filter @repo/web run dev",
    "lint": "corepack pnpm -r --if-present run lint",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "clean": "corepack pnpm -r --if-present run clean && rm -rf node_modules",
    "run:ci": "corepack pnpm doctor && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test",
    "test": "corepack pnpm -r --if-present run test",
    "test:coverage": "corepack pnpm -r --if-present run test:coverage",
    "test:live:session": "corepack pnpm exec tsx scripts/test-session.ts",
    "test:live:create-session": "corepack pnpm exec tsx scripts/test-create-session.ts",
    "dev:local": "corepack pnpm --filter @repo/api-server run dev & corepack pnpm --filter @repo/web run dev & corepack pnpm --filter @repo/scripts run dev & wait",
    "doctor": "corepack pnpm exec tsx scripts/repo-doctor.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "ws": "^8.20.0"
  }
}
